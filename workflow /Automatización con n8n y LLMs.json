      "parameters": {
        "promptType": "define",
        "text": "=Clasifica el clima en una sola palabra.\n\nOpciones:\nNORMAL\nLLUVIA\nTORMENTA\n\nResponde SOLO UNA palabra en mayúsculas.\n\nDatos:\nTemperatura: {{ $json['Temperatura '] }}\nHumedad: {{$json.Humedad}}\nProbabilidad lluvia: {{$json.Probabilidad_Lluvia}}\nLluvia hoy: {{$json.Lluvia_Hoy}}",
